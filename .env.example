# 1. AI Studio Preview (Desenvolvimento)
# Vá em "Settings" -> "Environment Variables" e adicione:
USER_GEMINI_KEY=sua_chave_aqui

# 2. Vercel / Netlify (Produção)
# Nas configurações de Environment Variables da plataforma, use EXATAMENTE este nome:
VITE_USER_GEMINI_KEY=sua_chave_aqui

# Configurações do Firebase
VITE_FIREBASE_API_KEY=
